lerna-debug.log*

# =========================
# 🏗️ Build / Output Folders
# =========================
dist/
dist-ssr/
build/
backend/dist/
frontend/dist/
coverage/
.cache/
*.local

# =========================
# 🔑 Environment Files
# =========================
# Don't commit sensitive info like DB credentials or API keys
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# =========================
# 🧠 Backend Specific Files
# =========================
# Logs and runtime data
backend/logs/
logs/
*.log
*.log.*

# Uploads folder (for images, product photos, etc.)
uploads/
public/uploads/

# Temporary data
tmp/
data/temp/
*.pid
*.seed

# Config files that may contain secrets
backend/config/
config.js
config/*.json

# =========================
# 💅 Frontend Specific Files
# =========================
# Build cache and local env
frontend/.env
frontend/.cache/
frontend/node_modules/
frontend/dist/

# React build artifacts
.vite/
vite.config.ts.timestamp*
vite.config.js.timestamp*

# =========================
# 🧩 IDE / Editor Settings
# =========================
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# =========================
# 🌍 Deployment Files
# =========================
# Firebase / Vercel / Render local caches
.firebase/
.firebaserc
.vercel/
.render/

# Docker and container files
Dockerfile
docker-compose.yml
*.tar

# =========================
# 💻 System Files
# =========================
Thumbs.db
desktop.ini
